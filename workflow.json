    {
      "parameters": {
        "jsCode": "const claudeResults = $input.all();\nconst originalJobs = $('Dedupe').all();\nconst items = [];\n\nfor (let i = 0; i < claudeResults.length; i++) {\n  const claudeOutput = claudeResults[i].json.output;\n  const original = originalJobs[i].json;\n\n  if (!claudeOutput.is_match) continue;\n\n  const url = original.url || '';\n  let hash = 0;\n  for (let j = 0; j < url.length; j++) {\n    hash = ((hash << 5) - hash) + url.charCodeAt(j);\n    hash |= 0;\n  }\n\n  items.push({\n    json: {\n      \"Job Tracker ID\": Math.abs(hash).toString(),\n      \"Company Name\": original.company || '',\n      \"Source\": original.source || 'Career Pages',\n      \"Application URL\": url,\n      \"Archetype\": claudeOutput.archetype || '',\n      \"Job Title\": original.title || '',\n      \"Job Vacancy ID\": original.vacancy_id || '',\n      \"Description\": original.description || '',\n      \"Application Status\": \"Not Started\",\n      \"Created At\": new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' })\n    }\n  });\n}\n\nif (items.length === 0) {\n  return [{ json: { no_matches: true } }];\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
