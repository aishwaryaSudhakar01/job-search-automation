      "name": "Parse Email",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const items = [];\n\n// existing tracker URLs (loaded just before this node)\nconst trackerItems = $('Load All Tracker URLs').all();\nconst existingUrls = new Set(\n  trackerItems\n    .map(item => item.json['Application URL'])\n    .filter(Boolean)\n    .map(url => url.toLowerCase().trim())\n);\n\n// all merged jobs from every source\nconst jobItems = $('Merge').all();\n\n// first pass: collect URLs that came from Gmail\nconst gmailUrls = new Set();\nfor (const item of jobItems) {\n  if (item.json.ats_type === 'gmail') {\n    const url = (item.json.url || '').toLowerCase().trim();\n    if (url) gmailUrls.add(url);\n  }\n}\n\n// second pass: dedupe against tracker, within-run, and career-page-vs-Gmail\nconst seenInRun = new Set();\nfor (const item of jobItems) {\n  const url = (item.json.url || '').toLowerCase().trim();\n\n  if (!url) continue;\n  if (existingUrls.has(url)) continue;\n  if (seenInRun.has(url)) continue;\n  if (item.json.ats_type !== 'gmail' && gmailUrls.has(url)) continue;\n\n  seenInRun.add(url);\n  items.push({ json: item.json });\n}\n\nif (items.length === 0) {\n  return [{ json: { no_matches: true } }];\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
